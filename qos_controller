from pox.core import core
import pox.openflow.libopenflow_01 as of
from pox.lib.packet import ethernet, ipv4, tcp

log = core.getLogger()

def install_flow(event, priority, match, idle_timeout=10, hard_timeout=30):
    msg = of.ofp_flow_mod()
    msg.priority = priority
    msg.match = match
    msg.idle_timeout = idle_timeout   # soft timeout
    msg.hard_timeout = hard_timeout   # hard timeout
    msg.actions.append(of.ofp_action_output(port=of.OFPP_FLOOD))
    event.connection.send(msg)


def _handle_ConnectionUp(event):
    log.info("Switch connected")

    # Default rule
    msg = of.ofp_flow_mod()
    msg.priority = 0
    msg.actions.append(of.ofp_action_output(port=of.OFPP_FLOOD))
    event.connection.send(msg)


def _handle_PacketIn(event):
    packet = event.parsed
    ip_packet = packet.find('ipv4')

    if not ip_packet:
        return

    tcp_packet = packet.find('tcp')

    if tcp_packet:
        dst_port = tcp_packet.dstport

        match = of.ofp_match.from_packet(packet)

        # 🔥 PRIORITY LOGIC

        if dst_port == 80:  # HTTP
            install_flow(event, priority=20, match=match)
            log.info("HTTP traffic - MEDIUM priority")

        elif dst_port == 443:  # HTTPS
            install_flow(event, priority=30, match=match)
            log.info("HTTPS traffic - HIGH priority")

        elif dst_port == 21:  # FTP
            install_flow(event, priority=10, match=match)
            log.info("FTP traffic - LOW priority")

        elif dst_port == 25:  # SMTP
            install_flow(event, priority=15, match=match)
            log.info("SMTP traffic - MEDIUM priority")

        else:
            install_flow(event, priority=5, match=match)
            log.info("Other TCP traffic - LOWEST priority")

    elif packet.find('icmp'):
        match = of.ofp_match.from_packet(packet)
        install_flow(event, priority=40, match=match)
        log.info("ICMP - HIGHEST priority")


def launch():
    core.openflow.addListenerByName("ConnectionUp", _handle_ConnectionUp)
    core.openflow.addListenerByName("PacketIn", _handle_PacketIn)
