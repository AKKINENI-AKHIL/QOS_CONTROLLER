from pox.core import core
import pox.openflow.libopenflow_01 as of

log = core.getLogger()

# -------- PRIORITY DEFINITIONS --------
PRIORITY_ICMP = 50
PRIORITY_HTTP = 40
PRIORITY_SMTP = 30
PRIORITY_FTP  = 20
PRIORITY_DEFAULT = 10

IDLE_TIMEOUT = 60
HARD_TIMEOUT = 120


def add_flow(event, priority, match):
    msg = of.ofp_flow_mod()
    msg.priority = priority
    msg.match = match
    msg.idle_timeout = IDLE_TIMEOUT
    msg.hard_timeout = HARD_TIMEOUT
    msg.actions.append(of.ofp_action_output(port=of.OFPP_FLOOD))
    event.connection.send(msg)


def _handle_ConnectionUp(event):
    log.info("Switch connected")

    # Default rule (lowest priority)
    msg = of.ofp_flow_mod()
    msg.priority = PRIORITY_DEFAULT
    msg.actions.append(of.ofp_action_output(port=of.OFPP_FLOOD))
    event.connection.send(msg)


def _handle_PacketIn(event):
    packet = event.parsed

    # -------- ICMP --------
    if packet.find('icmp'):
        match = of.ofp_match.from_packet(packet)
        add_flow(event, PRIORITY_ICMP, match)
        log.info("ICMP → priority %s", PRIORITY_ICMP)
        return

    # -------- TCP --------
    tcp = packet.find('tcp')

    if tcp:
        port = tcp.dstport
        match = of.ofp_match.from_packet(packet)

        if port == 8000:  # HTTP
            add_flow(event, PRIORITY_HTTP, match)
            log.info("HTTP → priority %s", PRIORITY_HTTP)

        elif port == 2525:  # SMTP
            add_flow(event, PRIORITY_SMTP, match)
            log.info("SMTP → priority %s", PRIORITY_SMTP)

        elif port == 2121:  # FTP
            add_flow(event, PRIORITY_FTP, match)
            log.info("FTP → priority %s", PRIORITY_FTP)

        else:
            add_flow(event, PRIORITY_DEFAULT, match)
            log.info("OTHER TCP → priority %s", PRIORITY_DEFAULT)


def launch():
    core.openflow.addListenerByName("ConnectionUp", _handle_ConnectionUp)
    core.openflow.addListenerByName("PacketIn", _handle_PacketIn)
